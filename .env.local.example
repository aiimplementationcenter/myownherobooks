# ── Stripe ──────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Vercel Blob ──────────────────────────────────
# Get from Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_STORE_ID=store_...
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Set to "true" once Blob is connected
NEXT_PUBLIC_BLOB_ENABLED=true

# ── SMTP ─────────────────────────────────────────
# Your mail server credentials
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false          # set to true if using port 465
SMTP_USER=you@yourdomain.com
SMTP_PASS=yourpassword
SMTP_FROM=hello@yourdomain.com   # optional — defaults to SMTP_USER if not set

# ── Business config ──────────────────────────────
# Email address to receive new order notifications
OWNER_EMAIL=you@yourdomain.com
