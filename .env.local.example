# ── Stripe ──────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...

# Webhook secret — get from `stripe listen` or Stripe Dashboard → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Vercel Blob ──────────────────────────────────
# Get from Vercel Dashboard → Storage → Blob → your store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...
# Set to "true" once Blob is connected; leave unset/false for local dev
NEXT_PUBLIC_BLOB_ENABLED=false

# ── Resend ───────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Business config ──────────────────────────────
# Email address to receive new order notifications
OWNER_EMAIL=you@yourdomain.com
